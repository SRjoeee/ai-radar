<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>AI News Radar RSS Example</title>
  </head>
  <body>
    <outline text="Official AI Sources">
      <outline
        text="OpenAI News"
        title="OpenAI News"
        type="rss"
        xmlUrl="https://openai.com/news/rss.xml"
        htmlUrl="https://openai.com/news"
      />
      <outline
        text="Hugging Face Blog"
        title="Hugging Face Blog"
        type="rss"
        xmlUrl="https://huggingface.co/blog/feed.xml"
        htmlUrl="https://huggingface.co/blog"
      />
      <outline
        text="Google DeepMind Blog"
        title="Google DeepMind Blog"
        type="rss"
        xmlUrl="https://deepmind.google/blog/rss.xml"
        htmlUrl="https://deepmind.google/discover/blog/"
      />
      <outline
        text="Google AI Blog"
        title="Google AI Blog"
        type="rss"
        xmlUrl="https://blog.google/technology/ai/rss/"
        htmlUrl="https://blog.google/technology/ai/"
      />
      <outline
        text="Microsoft AI Blog"
        title="Microsoft AI Blog"
        type="rss"
        xmlUrl="https://blogs.microsoft.com/ai/feed/"
        htmlUrl="https://blogs.microsoft.com/ai/"
      />
    </outline>
    <outline text="AI Media and Builders">
      <outline
        text="Wired AI"
        title="Wired AI"
        type="rss"
        xmlUrl="https://www.wired.com/feed/tag/ai/latest/rss"
        htmlUrl="https://www.wired.com/tag/artificial-intelligence/"
      />
      <outline
        text="InfoQ CN"
        title="InfoQ CN"
        type="rss"
        xmlUrl="https://www.infoq.cn/feed"
        htmlUrl="https://www.infoq.cn/"
      />
      <outline
        text="NVIDIA Generative AI Blog"
        title="NVIDIA Generative AI Blog"
        type="rss"
        xmlUrl="https://developer.nvidia.com/blog/category/generative-ai/feed/"
        htmlUrl="https://developer.nvidia.com/blog/category/generative-ai/"
      />
      <outline
        text="宝玉"
        title="宝玉"
        type="rss"
        xmlUrl="https://baoyu.io/feed.xml"
        htmlUrl="https://baoyu.io/"
      />
      <outline
        text="Simon Willison"
        title="Simon Willison"
        type="rss"
        xmlUrl="https://simonwillison.net/atom/everything/"
        htmlUrl="https://simonwillison.net/"
      />
    </outline>
    <outline text="AI Newsletters">
      <outline
        text="Marcus on AI (Gary Marcus)"
        title="Marcus on AI"
        type="rss"
        xmlUrl="https://garymarcus.substack.com/feed"
        htmlUrl="https://garymarcus.substack.com/"
      />
      <outline
        text="Latent Space"
        title="Latent Space"
        type="rss"
        xmlUrl="https://www.latent.space/feed"
        htmlUrl="https://www.latent.space/"
      />
      <outline
        text="Import AI (Jack Clark)"
        title="Import AI"
        type="rss"
        xmlUrl="https://importai.substack.com/feed"
        htmlUrl="https://importai.substack.com/"
      />
      <outline
        text="Interconnects (Nathan Lambert)"
        title="Interconnects"
        type="rss"
        xmlUrl="https://www.interconnects.ai/feed"
        htmlUrl="https://www.interconnects.ai/"
      />
      <outline
        text="Normal Technology (AI Snake Oil)"
        title="Normal Technology"
        type="rss"
        xmlUrl="https://www.normaltech.ai/feed"
        htmlUrl="https://www.normaltech.ai/"
      />
      <outline
        text="One Useful Thing (Ethan Mollick)"
        title="One Useful Thing"
        type="rss"
        xmlUrl="https://www.oneusefulthing.org/feed"
        htmlUrl="https://www.oneusefulthing.org/"
      />
      <outline
        text="Ahead of AI (Sebastian Raschka)"
        title="Ahead of AI"
        type="rss"
        xmlUrl="https://magazine.sebastianraschka.com/feed"
        htmlUrl="https://magazine.sebastianraschka.com/"
      />
      <outline
        text="Last Week in AI"
        title="Last Week in AI"
        type="rss"
        xmlUrl="https://lastweekin.ai/feed"
        htmlUrl="https://lastweekin.ai/"
      />
    </outline>
  </body>
</opml>
